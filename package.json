{
  "name": "foodbook",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Static-site archive of the food lifecycle — farms, gardens, kitchens, restaurants. Astro on Cloudflare Pages.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "biome ci",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract": "node scripts/ai-extract-recipe.mjs",
    "research:restaurants": "node scripts/research-restaurants.mjs",
    "embeddings": "node scripts/build-embeddings.mjs",
    "check:refs": "node scripts/check-refs.mjs",
    "check:leaks": "bash scripts/check-no-leaks.sh",
    "audit:photos": "node scripts/audit-hero-photos.mjs",
    "favicons": "node scripts/gen-favicons.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@types/leaflet": "^1.9.21",
    "astro": "^6.3.3",
    "astro-pagefind": "^2.0.0",
    "d3-shape": "^3.2.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.15",
    "@types/d3-shape": "^3.1.8",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
