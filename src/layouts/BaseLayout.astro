---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces/full.css';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
  unlisted?: boolean;
  /** Toggle the cook-mode kitchen theme. Only set on /recipes/<slug>/cook. */
  cookMode?: boolean;
  /** Local image stem (no size suffix). Resolves to `${hero}-1280.jpg` for og:image. */
  hero?: string;
  /** External hero URL (e.g. Wikimedia). Takes precedence over `hero`. */
  heroUrl?: string;
  /** OpenGraph type. 'website' for /, listings, error pages; 'article'
   *  for editorial entries (dishes/recipes/farms/restaurants/meals/garden). */
  ogType?: 'website' | 'article';
}

const SITE_NAME = 'Foodbook';
const SITE_TAGLINE = 'An archive of the food lifecycle';
const {
  title,
  description,
  unlisted = false,
  cookMode = false,
  hero,
  heroUrl,
  ogType = 'website',
} = Astro.props;
// astro.config.mjs sets `site`; if a future reorganization drops it we want
// the build to fail loudly rather than silently emit a wrong-domain canonical.
if (!Astro.site) {
  throw new Error('Astro.site must be set in astro.config.mjs');
}
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage =
  heroUrl ??
  (hero ? new URL(`${hero}-1280.jpg`, Astro.site).toString() : null) ??
  new URL('/og-default.svg', Astro.site).toString();
// Doubled-brand title bug: when title equals the site name (or is empty),
// render a descriptive title instead of "Foodbook · Foodbook".
const isBrandTitle = !title || title === SITE_NAME;
const fullTitle = isBrandTitle ? `${SITE_NAME} — ${SITE_TAGLINE}` : `${title} · ${SITE_NAME}`;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-mode={cookMode ? 'cook' : 'editorial'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0d11" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Foodbook" href="/rss.xml" />
    {unlisted && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <a class="brand" href="/">Foodbook</a>
      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label="Open navigation"
      >
        <span class="nav-toggle__bar" aria-hidden="true"></span>
        <span class="nav-toggle__bar" aria-hidden="true"></span>
        <span class="nav-toggle__bar" aria-hidden="true"></span>
      </button>
      <nav id="primary-nav" aria-label="Primary" data-open="false">
        <a href="/dishes/" aria-current={Astro.url.pathname.startsWith('/dishes') ? 'page' : undefined}>Dishes</a>
        <a href="/world/" aria-current={Astro.url.pathname.startsWith('/world') ? 'page' : undefined}>World</a>
        <a href="/seasons/" aria-current={Astro.url.pathname.startsWith('/seasons') ? 'page' : undefined}>Seasons</a>
        <a href="/restaurants/" aria-current={Astro.url.pathname.startsWith('/restaurants') ? 'page' : undefined}>Restaurants</a>
        <a href="/farms/" aria-current={Astro.url.pathname.startsWith('/farms') ? 'page' : undefined}>Farms</a>
      </nav>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          Foodbook — a static-site archive of the food lifecycle. Authored prose, AI-assisted
          authoring (<a href="/about#ai">how</a>).
        </p>
        <p class="footer-meta">
          &copy; {currentYear} Foodbook · <a href="/rss.xml">RSS</a> · <a href="/sitemap-index.xml">Sitemap</a>
        </p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      const nav = document.getElementById('primary-nav');

      function setNav(open: boolean): void {
        if (nav) nav.dataset.open = String(open);
        toggle?.setAttribute('aria-expanded', String(open));
        toggle?.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
      }

      toggle?.addEventListener('click', () => {
        setNav(nav?.dataset.open !== 'true');
      });
      nav?.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => setNav(false));
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && nav?.dataset.open === 'true') {
          setNav(false);
          toggle?.focus();
        }
      });
    </script>
  </body>
</html>
