---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SeasonalWheel from '~/components/SeasonalWheel.astro';
import {
  collectProducts,
  inSeason,
  MONTH_NAMES_LONG,
} from '~/lib/seasons';
import { publicOnly } from '~/lib/visibility';

const farms = publicOnly(await getCollection('farms'));
const month = new Date().getMonth() + 1; // 1-12

const products = collectProducts(farms);
const inSeasonNow = products.filter((p) => inSeason(p.from, p.to, month));
---

<BaseLayout
  title="Seasons"
  description="A wheel of what's in season right now — drawn from farm + producer windows."
>
  <section class="container" style="padding: 4rem 0;">
    <p class="eyebrow">{MONTH_NAMES_LONG[month - 1]}</p>
    <h1>In season now</h1>
    <p class="lead">
      Each ring is a product authored on a farm or producer entry. The wedge
      glowing behind the wheel is the current month — products falling inside
      it are filled paprika.
    </p>

    <SeasonalWheel farms={farms} currentMonth={month} />

    <div class="legend">
      <h2>Right now</h2>
      {inSeasonNow.length === 0 ? (
        <p class="muted">No products have a window covering {MONTH_NAMES_LONG[month - 1]} yet.</p>
      ) : (
        <ul>
          {inSeasonNow.map((p) => (
            <li>
              <strong>{p.product}</strong>
              <span class="muted"> — {p.farms.map((f) => f.name).join(', ')}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .legend {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .legend h2 {
    margin-bottom: 1rem;
  }

  .legend ul {
    columns: 2;
    column-gap: 2rem;
    padding: 0;
    list-style: none;
    margin: 0;
  }

  .legend li {
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--rule);
    break-inside: avoid;
    max-width: none;
  }

  .legend .muted {
    color: var(--ink-mute);
  }
</style>
