---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import JsonLd from '~/components/JsonLd.astro';
import { SCHEMA_CTX, breadcrumb, entryUrl } from '~/lib/jsonld';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { slug: recipe.id.replace(/^recipes\//, '') },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const slug = recipe.id.replace(/^recipes\//, '');
const { Content } = await render(recipe);

// Look up the producer for an ingredient's `from` slug across farms and
// garden collections. Returns the right href and display name, or null
// if the slug doesn't resolve (renderer falls back to plain text).
// glob loader includes the collection prefix in `id` (e.g. `farms/<slug>`),
// so strip it when comparing to the bare `ing.from`.
const farms = await getCollection('farms');
const gardens = await getCollection('garden');
function bare(id: string): string {
  return id.replace(/^[^/]+\//, '');
}
function findProducer(s: string): { href: string; label: string } | null {
  const farm = farms.find((f) => bare(f.id) === s);
  if (farm) return { href: `/farms/${bare(farm.id)}/`, label: farm.data.name };
  const garden = gardens.find((g) => bare(g.id) === s);
  if (garden) return { href: `/garden/${bare(garden.id)}/`, label: garden.data.plant };
  return null;
}

// Group ingredients by `group` field, preserving order of first occurrence.
const groups = new Map<string, typeof recipe.data.ingredients>();
for (const ing of recipe.data.ingredients) {
  const k = ing.group ?? '';
  if (!groups.has(k)) groups.set(k, []);
  groups.get(k)!.push(ing);
}

/** Returns undefined for unparseable inputs; schema.org tolerates absence. */
function isoDuration(s: string | undefined): string | undefined {
  if (!s) return undefined;
  const trimmed = s.trim().toLowerCase();
  const hMatch = trimmed.match(/(\d+(?:\.\d+)?)\s*h(?:our)?s?/);
  const mMatch = trimmed.match(/(\d+(?:\.\d+)?)\s*m(?:in)?(?:ute)?s?/);
  const hours = hMatch ? Number(hMatch[1]) : 0;
  const minutes = mMatch ? Number(mMatch[1]) : 0;
  if (hours === 0 && minutes === 0) return undefined;
  const totalMinutes = Math.round(hours * 60 + minutes);
  const h = Math.floor(totalMinutes / 60);
  const m = totalMinutes % 60;
  return `PT${h ? `${h}H` : ''}${m ? `${m}M` : ''}`;
}

const site = Astro.site!;
const recipeUrl = entryUrl(site, 'recipes', slug);
// Strip <em> markup from the recipe title for the meta description (plain text only).
const plainTitle = recipe.data.title.replace(/<\/?em>/g, '');
const description = [
  plainTitle,
  recipe.data.yield,
  recipe.data.timePrep && `prep ${recipe.data.timePrep}`,
  recipe.data.timeCook && `cook ${recipe.data.timeCook}`,
  recipe.data.attribution && `via ${recipe.data.attribution}`,
].filter(Boolean).join(' · ').slice(0, 155);
const prepIso = isoDuration(recipe.data.timePrep);
const cookIso = isoDuration(recipe.data.timeCook);

const recipeLd = {
  '@context': SCHEMA_CTX,
  '@type': 'Recipe',
  name: recipe.data.title,
  description,
  recipeYield: recipe.data.yield,
  url: recipeUrl,
  // schema.org wants plain ingredient strings; entry-page UI keeps the structured refs.
  recipeIngredient: recipe.data.ingredients.map((i) => i.text),
  recipeInstructions: recipe.data.steps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    text: s.text,
  })),
  ...(prepIso && { prepTime: prepIso }),
  ...(cookIso && { cookTime: cookIso }),
  ...(recipe.data.heroUrl && { image: recipe.data.heroUrl }),
  ...(recipe.data.attribution && { author: { '@type': 'Person', name: recipe.data.attribution } }),
};

const breadcrumbLd = breadcrumb(
  site,
  { label: 'Recipes', kind: 'recipes' },
  { label: recipe.data.title, url: recipeUrl },
);
---

<BaseLayout
  title={recipe.data.title}
  description={description}
  unlisted={recipe.data.visibility === 'unlisted'}
  hero={recipe.data.hero}
  heroUrl={recipe.data.heroUrl}
  ogType="article"
>
  <JsonLd data={recipeLd} />
  <JsonLd data={breadcrumbLd} />
  <section class="container" style="padding: 4rem 0;">
    <p class="eyebrow">Recipe</p>
    <h1>{recipe.data.title}</h1>
    <p class="lead">
      {recipe.data.yield}
      {recipe.data.timePrep && <> · prep {recipe.data.timePrep}</>}
      {recipe.data.timeCook && <> · cook {recipe.data.timeCook}</>}
    </p>

    <p style="margin-top: 1.5rem;">
      <a href={`/recipes/${slug}/cook/`} style="font-weight: 500;">→ Open in cook mode</a>
    </p>

    {recipe.data.attribution && (
      <p style="color: var(--ink-mute); font-size: 0.88rem; margin-top: 1rem;">
        {recipe.data.attribution}
      </p>
    )}

    <h2 style="margin-top: 3rem;">Ingredients</h2>
    {[...groups.entries()].map(([groupName, items]) => (
      <>
        {groupName && <h3 style="margin-top: 1.5rem;">{groupName}</h3>}
        <ul>
          {items.map((ing) => {
            const producer = ing.from ? findProducer(ing.from) : null;
            return (
              <li>
                {ing.text}
                {producer && <> — <a href={producer.href}>{producer.label}</a></>}
                {ing.from && !producer && <> — <span>{ing.from}</span></>}
              </li>
            );
          })}
        </ul>
      </>
    ))}

    <h2 style="margin-top: 3rem;">Method</h2>
    <ol>
      {recipe.data.steps.map((step) => (
        <li style="margin-bottom: 1rem;">
          {step.text}
          {step.durationSeconds && (
            <span style="color: var(--ink-mute); margin-left: 0.5rem; font-size: 0.9rem;">
              · {Math.round(step.durationSeconds / 60)} min
            </span>
          )}
        </li>
      ))}
    </ol>

    {recipe.data.notes && (
      <>
        <h2 style="margin-top: 3rem;">Notes</h2>
        <Content />
        <pre style="white-space: pre-wrap; font-family: var(--font-body); color: var(--ink-soft);">{recipe.data.notes}</pre>
      </>
    )}
  </section>
</BaseLayout>
