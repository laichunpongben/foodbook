---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="No such page in this archive.">
  <section class="not-found">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p class="lead">
      The page you were looking for isn't in the archive. The slug may be wrong, the entry may
      have been removed, or the page may not exist yet.
    </p>
    <ul class="not-found-nav">
      <li><a href="/">Home</a></li>
      <li><a href="/world/">World</a></li>
      <li><a href="/seasons/">Seasons</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .not-found {
    max-width: 36rem;
    margin: 6rem auto;
    padding: 0 1.5rem;
    text-align: center;
  }
  .not-found .eyebrow {
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.5rem;
  }
  .not-found h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1.25rem;
  }
  .not-found .lead {
    color: var(--ink-soft);
    margin: 0 0 2rem;
  }
  .not-found-nav {
    list-style: none;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin: 0;
  }
  .not-found-nav a {
    color: var(--paprika);
  }
</style>
