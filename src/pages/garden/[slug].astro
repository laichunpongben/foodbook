---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import AppearsIn from '~/components/AppearsIn.astro';
import { dishesReferencing } from '~/lib/back-refs';
import { isHidden } from '~/lib/visibility';

export async function getStaticPaths() {
  const beds = await getCollection('garden');
  return beds.map((g) => ({
    params: { slug: g.id.replace(/^garden\//, '') },
    props: { bed: g },
  }));
}

const { bed } = Astro.props;
const slug = bed.id.replace(/^garden\//, '');
const { Content } = await render(bed);
const dishes = await dishesReferencing('garden', slug);
const d = bed.data;
---

<BaseLayout
  title={`${d.plant} · ${d.bed}`}
  description={`Garden log: ${d.plant}`}
  unlisted={isHidden(bed)}
>
  {d.heroUrl && (
    <div class="entity-banner" style={`background-image: url('${d.heroUrl}')`}>
      <div class="banner-scrim"></div>
    </div>
  )}
  <article class="entity container">
    <a class="back" href="/">← Dishes</a>

    <p class="eyebrow">Grow · {d.bed}</p>
    <h1>{d.plant}</h1>
    <p class="lead">
      Planted <strong>{d.planted}</strong>
      {d.harvested && <> · harvested <strong>{d.harvested}</strong></>}
    </p>

    {d.yieldNote && <p><strong>Yield:</strong> {d.yieldNote}</p>}
    {d.note && <p set:html={d.note} />}

    <Content />

    <AppearsIn dishes={dishes} label="Used in" />
  </article>
</BaseLayout>

<style>
  .entity-banner {
    position: relative;
    height: 38vh;
    min-height: 240px;
    background-size: cover;
    background-position: center;
    background-color: #0a0d11;
  }
  .banner-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,13,17,0.25) 0%, rgba(10,13,17,0.9) 100%);
  }
  .entity { padding: 3rem 0 6rem; max-width: 760px; }
  .back {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--ink-mute);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
  }
  .back:hover { color: var(--paprika); }
</style>
