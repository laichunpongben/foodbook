---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SunSection from '~/components/SunSection.astro';
import PlantSection from '~/components/PlantSection.astro';
import CookSection from '~/components/CookSection.astro';
import PlateSection from '~/components/PlateSection.astro';
import EatSection from '~/components/EatSection.astro';
import { getJourney } from '~/lib/journey';

export async function getStaticPaths() {
  const dishes = await getCollection('dishes');
  return dishes.map((dish) => ({
    params: { slug: dish.id.replace(/^dishes\//, '') },
    props: { dish },
  }));
}

const { dish } = Astro.props;
const { Content } = await render(dish);
const journey = await getJourney(dish);

const hasIngredients = journey.ingredients.length > 0;
const hasRecipes = journey.cook.length > 0;
const hasEats = journey.eat.length > 0;
---

<BaseLayout
  title={dish.data.shortTitle}
  description={dish.data.tagline}
  unlisted={dish.data.visibility === 'unlisted'}
>
  <article class="dish-journey">
    <!-- 1 · Sun — frames the energy story -->
    <SunSection />

    <!-- 2 · Plant — ingredients with their origins -->
    {hasIngredients && <PlantSection ingredients={journey.ingredients} />}

    <!-- 3 · Cook — the recipe(s) -->
    {hasRecipes && <CookSection recipes={journey.cook} />}

    <!-- 4 · Plate — the reveal: the assembled dish -->
    <PlateSection dish={journey.dish} />

    <!-- 5 · Eat — meals + restaurants -->
    {hasEats && <EatSection eats={journey.eat} />}

    <!-- Prose body (prologue / MDX content / finale) -->
    {(dish.data.prologue || dish.data.finale) && (
      <section class="dish-prose">
        <div class="container">
          {dish.data.prologue && (
            <section class="prologue">
              <h2 set:html={dish.data.prologue.heading} />
              <p set:html={dish.data.prologue.prose} />
            </section>
          )}

          <Content />

          {dish.data.finale && (
            <section class="finale">
              <h2 set:html={dish.data.finale.heading} />
              <p set:html={dish.data.finale.prose} />
            </section>
          )}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style is:global>
  /* Shared rhythm across all section components — global so each
   * section component doesn't have to redeclare the same eyebrow + */
  .journey-section { width: 100%; }

  .journey-section .stage-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: rgba(15, 18, 24, 0.5);
    backdrop-filter: blur(4px);
  }
</style>

<style>
  .dish-prose {
    background: rgba(10, 13, 17, 1);
    padding: 5rem 0 7rem;
  }

  .dish-prose .prologue,
  .dish-prose .finale {
    margin: 2.5rem 0;
    max-width: var(--measure);
  }

  .dish-prose .prologue h2,
  .dish-prose .finale h2 {
    margin-bottom: 0.6rem;
  }
</style>
