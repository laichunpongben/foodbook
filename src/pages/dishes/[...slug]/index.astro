---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import JsonLd from '~/components/JsonLd.astro';
import { SCHEMA_CTX, breadcrumb, entryUrl } from '~/lib/jsonld';
import DishHero from '~/components/DishHero.astro';
import PlantSection from '~/components/PlantSection.astro';
import CookSection from '~/components/CookSection.astro';
import PlateSection from '~/components/PlateSection.astro';
import EatSection from '~/components/EatSection.astro';
import { getJourney } from '~/lib/journey';

export async function getStaticPaths() {
  const dishes = await getCollection('dishes');
  return dishes.map((dish) => ({
    params: { slug: dish.id.replace(/^dishes\//, '') },
    props: { dish },
  }));
}

const { dish } = Astro.props;
const slug = dish.id.replace(/^dishes\//, '');
const { Content } = await render(dish);
const journey = await getJourney(dish);

const hasIngredients = journey.ingredients.length > 0;
const hasRecipes = journey.cook.length > 0;
const hasEats = journey.eat.length > 0;
const heroScrollTo = hasIngredients ? '#plant' : hasRecipes ? '#cook' : '#plate';

const site = Astro.site!;
const dishUrl = entryUrl(site, 'dishes', slug);
const articleLd = {
  '@context': SCHEMA_CTX,
  '@type': 'Article',
  headline: dish.data.shortTitle,
  url: dishUrl,
  ...(dish.data.tagline && { description: dish.data.tagline }),
  ...(dish.data.heroUrl && { image: dish.data.heroUrl }),
  ...(dish.data.firstMade && { dateCreated: dish.data.firstMade }),
  ...(dish.data.origin && { about: dish.data.origin }),
};

const breadcrumbLd = breadcrumb(
  site,
  { label: 'Dishes', kind: 'dishes' },
  { label: dish.data.shortTitle, url: dishUrl },
);
---

<BaseLayout
  title={dish.data.shortTitle}
  description={dish.data.tagline}
  unlisted={dish.data.visibility === 'unlisted'}
  hero={dish.data.hero}
  heroUrl={dish.data.heroUrl}
  ogType="article"
>
  <JsonLd data={articleLd} />
  <JsonLd data={breadcrumbLd} />
  <article class="dish-journey">
    <!-- Hero — per-dish opener driven by frontmatter (title, tagline,
         origin, hero image, prologue) -->
    <DishHero dish={dish} scrollTo={heroScrollTo} />

    <!-- Plant — ingredients with their origins -->
    {hasIngredients && <PlantSection ingredients={journey.ingredients} />}

    <!-- 3 · Cook — the recipe(s) -->
    {hasRecipes && <CookSection recipes={journey.cook} />}

    <!-- 4 · Plate — the reveal: the assembled dish -->
    <PlateSection dish={journey.dish} />

    <!-- 5 · Eat — meals + restaurants -->
    {hasEats && <EatSection eats={journey.eat} />}

    <!-- Prose body (MDX content + finale). Prologue is now rendered
         inside DishHero above. -->
    <section class="dish-prose">
      <div class="container">
        <Content />

        {dish.data.finale && (
          <section class="finale">
            <h2 set:html={dish.data.finale.heading} />
            <p set:html={dish.data.finale.prose} />
          </section>
        )}
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  /* Shared rhythm across all section components — global so each
   * section component doesn't have to redeclare the same eyebrow + */
  .journey-section { width: 100%; }

  .journey-section .stage-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: rgba(15, 18, 24, 0.5);
    backdrop-filter: blur(4px);
  }
</style>

<style>
  .dish-prose {
    background: rgba(10, 13, 17, 1);
    padding: 5rem 0 7rem;
  }

  .dish-prose .finale {
    margin: 2.5rem 0;
    max-width: var(--measure);
  }

  .dish-prose .finale h2 {
    margin-bottom: 0.6rem;
  }
</style>
