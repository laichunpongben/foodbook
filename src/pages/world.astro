---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { publicOnly } from '~/lib/visibility';
import type { MapPin } from '~/lib/map/food';

const farms = publicOnly(await getCollection('farms'));
const restaurants = publicOnly(await getCollection('restaurants'));

const restaurantStatus = (r: typeof restaurants[number]): 'visited' | 'discovered' => {
  if (r.data.visits.length > 0) return 'visited';
  if (r.data.discoveredVia) return 'discovered';
  return 'visited';
};

const pins: MapPin[] = [
  ...farms.map<MapPin>((f) => ({
    slug: f.id,
    name: f.data.name,
    lat: f.data.lat,
    lng: f.data.lng,
    kind: f.data.kind,
    location: f.data.location,
    heroUrl: f.data.heroUrl,
    href: `/farms/${f.id}/`,
  })),
  ...restaurants.map<MapPin>((r) => ({
    slug: r.id,
    name: r.data.name,
    lat: r.data.lat,
    lng: r.data.lng,
    kind: 'restaurant',
    status: restaurantStatus(r),
    city: r.data.city,
    heroUrl: r.data.heroUrl,
    href: `/restaurants/${r.id}/`,
  })),
];

const farmCount = farms.length;
const restaurantCount = restaurants.length;
---

<BaseLayout
  title="World"
  description="A map of where food comes from — farms, producers, markets, restaurants."
>
  <section class="container" style="padding: 4rem 0;">
    <p class="eyebrow">Terroir + table</p>
    <h1>World food map</h1>
    <p class="lead">
      Farms, producers, and markets on one layer; restaurants on another —
      filled paprika for places visited, hollow rings for places only discovered.
      {farmCount} {farmCount === 1 ? 'farm' : 'farms'} ·
      {restaurantCount} {restaurantCount === 1 ? 'restaurant' : 'restaurants'}.
    </p>
    <div
      id="food-map"
      data-pins={JSON.stringify(pins)}
      role="application"
      aria-label="Interactive map of farms and restaurants. A text list of all locations is provided below."
    />

    <!-- Screen-reader / no-JS / SEO fallback: every map pin as a real link.
         Visually hidden by default; revealed when JS is disabled. See #20. -->
    <section class="sr-only-list" aria-label="Map locations">
      <h2>All locations</h2>
      {farms.length > 0 && (
        <>
          <h3>Farms &amp; producers</h3>
          <ul>
            {farms.map((f) => (
              <li>
                <a href={`/farms/${f.id.replace(/^farms\//, '')}/`}>{f.data.name}</a>
                {' — '}{f.data.kind} at {f.data.location}{f.data.country && `, ${f.data.country}`}
              </li>
            ))}
          </ul>
        </>
      )}
      {restaurants.length > 0 && (
        <>
          <h3>Restaurants</h3>
          <ul>
            {restaurants.map((r) => (
              <li>
                <a href={`/restaurants/${r.id.replace(/^restaurants\//, '')}/`}>{r.data.name}</a>
                {' — '}{[r.data.cuisine, r.data.city, r.data.country].filter(Boolean).join(', ')}
              </li>
            ))}
          </ul>
        </>
      )}
    </section>
  </section>
</BaseLayout>

<style>
  #food-map {
    height: 70vh;
    margin-top: 2rem;
    border-radius: 6px;
    overflow: hidden;
    background: #11161c;
  }
  /* Visually hidden but reachable by screen readers, search engines,
   * and users with JS disabled. WCAG 1.1.1 / 4.1.2 — see #20. */
  .sr-only-list {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<style is:global>
  /* Leaflet popup + controls — dark-theme overrides. is:global because
   * Leaflet inserts these nodes at runtime, outside Astro's scoped tree. */
  .food-map-popup .leaflet-popup-content-wrapper {
    background: #11161c;
    color: var(--ink);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    padding: 0;
  }

  .food-map-popup .leaflet-popup-content {
    margin: 0;
    width: 220px !important;
  }

  .food-map-popup .leaflet-popup-tip {
    background: #11161c;
  }

  .food-map-popup__photo {
    display: block;
    width: 100%;
    height: 110px;
    object-fit: cover;
    border-radius: 6px 6px 0 0;
    background: #0a0d11;
  }

  .food-map-popup__body {
    padding: 0.7rem 0.9rem 0.9rem;
  }

  .food-map-popup__kind {
    margin: 0 0 0.25rem;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .food-map-popup__name {
    margin: 0 0 0.2rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .food-map-popup__name a {
    color: var(--ink);
    text-decoration: none;
  }

  .food-map-popup__name a:hover { color: var(--paprika); }

  .food-map-popup__sub {
    margin: 0;
    font-size: 0.82rem;
    color: var(--ink-soft);
  }

  /* Layer control + attribution on dark theme */
  .leaflet-control-layers {
    background: rgba(17, 22, 28, 0.92) !important;
    color: var(--ink) !important;
    border: 1px solid var(--rule) !important;
    border-radius: 6px !important;
    padding: 0.45rem 0.6rem !important;
    font-family: var(--font-body);
    font-size: 0.85rem;
  }

  .leaflet-control-layers label {
    color: var(--ink-soft) !important;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0.15rem 0;
  }

  .leaflet-control-attribution {
    background: rgba(10, 13, 17, 0.7) !important;
    color: var(--ink-mute) !important;
    font-size: 0.7rem !important;
  }

  .leaflet-control-attribution a {
    color: var(--ink-soft) !important;
  }

  .leaflet-control-zoom a {
    background: rgba(17, 22, 28, 0.92) !important;
    color: var(--ink-soft) !important;
    border-color: var(--rule) !important;
  }

  .leaflet-control-zoom a:hover {
    background: rgba(210, 84, 59, 0.18) !important;
    color: var(--ink) !important;
  }
</style>

<script>
  import 'leaflet/dist/leaflet.css';
  import { mountFoodMap, type MapPin } from '~/lib/map/food';

  const el = document.getElementById('food-map');
  if (el && el.dataset.pins) {
    const pins = JSON.parse(el.dataset.pins) as MapPin[];
    mountFoodMap(el, pins);
  }
</script>
