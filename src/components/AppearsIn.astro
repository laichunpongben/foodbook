---
/**
 * AppearsIn — small "this entity is referenced by N dishes" panel.
 * Renders nothing if the list is empty.
 */

import type { CollectionEntry } from 'astro:content';

interface Props {
  dishes: CollectionEntry<'dishes'>[];
  label?: string;
}

const { dishes, label = 'Appears in' } = Astro.props;
---

{dishes.length > 0 && (
  <section class="appears-in">
    <p class="eyebrow">{label} · {dishes.length}</p>
    <ul>
      {dishes.map((d) => (
        <li>
          <a href={`/dishes/${d.id.replace(/^dishes\//, '')}/`} set:html={d.data.title} />
          {d.data.tagline && <span class="line">{d.data.tagline}</span>}
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .appears-in {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }
  .appears-in ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .appears-in li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .appears-in li a {
    font-family: var(--font-display);
    font-size: 1.15rem;
    text-decoration: none;
    color: var(--ink);
  }
  .appears-in li a:hover { color: var(--paprika); }
  .appears-in li .line { color: var(--ink-mute); font-size: 0.88rem; }
</style>
