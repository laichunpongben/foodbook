---
/**
 * SunSection — opening of the journey.
 *
 * Sets the conceptual frame: energy from the sun, photosynthesised
 * into plants, harvested, transformed, eaten. One short paragraph,
 * a warm gradient backdrop with a horizon photo, and a scroll cue.
 */
---

<section class="journey-section section-sun">
  <div class="sun-backdrop"></div>
  <div class="sun-scrim"></div>
  <div class="container sun-content">
    <p class="stage-eyebrow">1 · Sun</p>
    <h2 class="sun-heading">
      Every plate begins <em>93 million miles away.</em>
    </h2>
    <p class="sun-lead">
      Light becomes leaves, leaves become fruit, fruit becomes this dish.
      Energy from the sun, photosynthesised into the cellular structure
      of every ingredient that meets a knife.
    </p>
    <a class="scroll-cue" href="#plant" aria-label="Scroll to the plants">↓</a>
  </div>
</section>

<style>
  .section-sun {
    position: relative;
    min-height: 70vh;
    padding: 6rem 0;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .sun-backdrop {
    position: absolute;
    inset: 0;
    background-image: url('https://commons.wikimedia.org/wiki/Special:FilePath/Sunrise_over_the_sea.jpg?width=2560');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  .sun-scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(70% 60% at 50% 30%, rgba(255, 178, 102, 0.18), transparent 70%),
      linear-gradient(180deg, rgba(10, 13, 17, 0.45) 0%, rgba(10, 13, 17, 0.85) 100%);
    z-index: 1;
  }

  .sun-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .sun-heading {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4.5vw, 3.2rem);
    line-height: 1.1;
    max-width: 24ch;
    margin: 0 auto;
    color: var(--ink);
    text-shadow: 0 3px 14px rgba(0, 0, 0, 0.6);
  }

  .sun-heading em {
    color: rgba(255, 178, 102, 0.95);
    font-style: normal;
  }

  .sun-lead {
    margin: 1.5rem auto 0;
    max-width: 56ch;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--ink-soft);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  .scroll-cue {
    display: inline-block;
    margin-top: 3rem;
    width: 2.5rem;
    height: 2.5rem;
    line-height: 2.3rem;
    text-align: center;
    border: 1px solid rgba(255, 178, 102, 0.5);
    border-radius: 50%;
    color: rgba(255, 178, 102, 0.9);
    text-decoration: none;
    font-size: 1.1rem;
    transition: transform 0.3s ease;
    animation: bob 2.4s ease-in-out infinite;
  }
  .scroll-cue:hover { transform: scale(1.08); }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
  }
</style>
