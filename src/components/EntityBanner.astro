---
/**
 * EntityBanner — full-bleed hero on entry pages. Always the LCP element,
 * so the inner image is eager + high-priority by default.
 */
import WikiImage from '~/components/WikiImage.astro';

interface Props {
  url: string;
  alt: string;
}

const { url, alt } = Astro.props;
---

<div class="entity-banner">
  <WikiImage url={url} alt={alt} loading="eager" fetchpriority="high" sizes="100vw" />
  <div class="banner-scrim" aria-hidden="true"></div>
</div>

<style>
  .entity-banner {
    position: relative;
    height: 38vh;
    min-height: 240px;
    background-color: #0a0d11;
    overflow: hidden;
  }
  .entity-banner img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .banner-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 13, 17, 0.25) 0%, rgba(10, 13, 17, 0.9) 100%);
  }
</style>
