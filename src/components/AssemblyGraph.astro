---
/**
 * AssemblyGraph — the four-stage lifecycle of a dish.
 *
 *   Source  →  Grow  →  Cook  →  Eat
 *
 * The dish itself is NOT a node here — it's the subject of the
 * lifecycle and lives as the page header. Stages with no entries
 * collapse cleanly. Each card carries enough context (location,
 * time, key ingredients, date) that no click-through is needed.
 *
 * A SVG overlay draws cubic-bezier connectors between adjacent
 * populated stages; recomputed on resize, fonts-ready, and Astro
 * page-load. Below 720px the graph stacks vertically.
 */

import type { AssemblyGraph, Node } from '~/lib/assembly';

interface Props {
  graph: AssemblyGraph;
}

const { graph } = Astro.props;

const href = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return `/farms/${n.slug}/`;
    case 'garden':     return `/garden/${n.slug}/`;
    case 'recipe':     return `/recipes/${n.slug}/`;
    case 'meal':       return `/meals/${n.slug}/`;
    case 'restaurant': return `/restaurants/${n.slug}/`;
  }
};

const glyph = (kind: Node['kind']): string => {
  switch (kind) {
    case 'farm':       return '◖';
    case 'garden':     return '✿';
    case 'recipe':     return '✎';
    case 'meal':       return '◐';
    case 'restaurant': return '☖';
  }
};

const kindLabel = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return 'Producer';
    case 'garden':     return 'Garden';
    case 'recipe':     return 'Recipe';
    case 'meal':       return 'Meal';
    case 'restaurant': return n.status === 'visited' ? 'Restaurant · visited' : 'Restaurant · discovered';
  }
};

// Lifecycle order. Drop empty stages so they don't take up a column.
const columns = [
  { id: 'source', heading: 'Source', nodes: graph.source },
  { id: 'grow',   heading: 'Grow',   nodes: graph.grow },
  { id: 'cook',   heading: 'Cook',   nodes: graph.cook },
  { id: 'eat',    heading: 'Eat',    nodes: graph.eat },
].filter((c) => c.nodes.length > 0);
---

<section class="assembly" aria-label={`Lifecycle of ${graph.dish.label}`}>
  <div class="assembly-grid" data-columns={columns.length}>
    <svg class="assembly-edges" aria-hidden="true" preserveAspectRatio="none">
      <defs>
        <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5"
                markerWidth="5" markerHeight="5" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
        </marker>
      </defs>
    </svg>

    {columns.map((col, i) => (
      <div class={`assembly-col col-${col.id}`} data-col={col.id}>
        <p class="col-heading">
          <span class="col-step">{i + 1}</span>
          <span>{col.heading}</span>
        </p>
        <ul class="col-nodes">
          {col.nodes.map((n) => (
            <li>
              <a
                class={`node node-${n.kind} ${n.kind === 'restaurant' ? `is-${n.status}` : ''}`}
                href={href(n)}
                data-node-id={`${col.id}--${n.slug}`}
                style={n.heroUrl ? `background-image: url('${n.heroUrl}')` : undefined}
              >
                <span class="node-scrim" aria-hidden="true"></span>
                <span class="node-content">
                  <span class="node-glyph" aria-hidden="true">{glyph(n.kind)}</span>
                  <span class="node-kind-tag">{kindLabel(n)}</span>
                  <span class="node-label" set:html={n.label} />
                  {n.meta && <span class="node-meta">{n.meta}</span>}
                  {n.facts && n.facts.length > 0 && (
                    <ul class="node-facts">
                      {n.facts.map((f) => <li>{f}</li>)}
                    </ul>
                  )}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<script>
  function draw(root: HTMLElement) {
    const svg = root.querySelector('svg.assembly-edges') as SVGSVGElement | null;
    const grid = root.querySelector('.assembly-grid') as HTMLElement | null;
    if (!svg || !grid) return;

    svg.querySelectorAll('path.edge').forEach((p) => p.remove());

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    const rect = grid.getBoundingClientRect();
    svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
    svg.style.width = `${rect.width}px`;
    svg.style.height = `${rect.height}px`;

    const cols = Array.from(root.querySelectorAll<HTMLElement>('.assembly-col'));
    const stacked = matchMedia('(max-width: 720px)').matches;

    for (let i = 0; i < cols.length - 1; i++) {
      const fromNodes = Array.from(cols[i].querySelectorAll<HTMLAnchorElement>('.node'));
      const toNodes = Array.from(cols[i + 1].querySelectorAll<HTMLAnchorElement>('.node'));

      for (const from of fromNodes) {
        for (const to of toNodes) {
          const fr = from.getBoundingClientRect();
          const tr = to.getBoundingClientRect();

          let x1: number, y1: number, x2: number, y2: number;
          let c1x: number, c1y: number, c2x: number, c2y: number;
          if (stacked) {
            x1 = fr.left + fr.width / 2 - rect.left;
            y1 = fr.bottom - rect.top;
            x2 = tr.left + tr.width / 2 - rect.left;
            y2 = tr.top - rect.top;
            const dy = Math.max(20, (y2 - y1) * 0.55);
            c1x = x1; c1y = y1 + dy;
            c2x = x2; c2y = y2 - dy;
          } else {
            x1 = fr.right - rect.left;
            y1 = fr.top + fr.height / 2 - rect.top;
            x2 = tr.left - rect.left;
            y2 = tr.top + tr.height / 2 - rect.top;
            const dx = Math.max(30, (x2 - x1) * 0.55);
            c1x = x1 + dx; c1y = y1;
            c2x = x2 - dx; c2y = y2;
          }

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', `M ${x1} ${y1} C ${c1x} ${c1y}, ${c2x} ${c2y}, ${x2} ${y2}`);
          path.setAttribute('class', 'edge');
          path.dataset.from = from.dataset.nodeId ?? '';
          path.dataset.to = to.dataset.nodeId ?? '';
          svg.appendChild(path);
        }
      }
    }
  }

  function init() {
    const root = document.querySelector('.assembly') as HTMLElement | null;
    if (!root) return;
    draw(root);
    const ro = new ResizeObserver(() => draw(root));
    ro.observe(root);
    root.addEventListener('mouseover', (e) => {
      const node = (e.target as HTMLElement).closest<HTMLAnchorElement>('.node');
      if (!node) return;
      const id = node.dataset.nodeId;
      root.querySelectorAll<SVGPathElement>('path.edge').forEach((p) => {
        p.classList.toggle('lit', p.dataset.from === id || p.dataset.to === id);
      });
      root.querySelectorAll<HTMLAnchorElement>('.node').forEach((n) => n.classList.remove('faded'));
      const touched = new Set<string>([id ?? '']);
      root.querySelectorAll<SVGPathElement>('path.edge.lit').forEach((p) => {
        if (p.dataset.from) touched.add(p.dataset.from);
        if (p.dataset.to) touched.add(p.dataset.to);
      });
      root.querySelectorAll<HTMLAnchorElement>('.node').forEach((n) => {
        if (!touched.has(n.dataset.nodeId ?? '')) n.classList.add('faded');
      });
    });
    root.addEventListener('mouseleave', () => {
      root.querySelectorAll<SVGPathElement>('path.edge.lit').forEach((p) => p.classList.remove('lit'));
      root.querySelectorAll<HTMLAnchorElement>('.node.faded').forEach((n) => n.classList.remove('faded'));
    });
    if ('fonts' in document) {
      document.fonts.ready.then(() => draw(root));
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .assembly { width: 100%; margin: 0; height: 100%; display: flex; }

  .assembly-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
    align-items: stretch;
    width: 100%;
  }

  .assembly-grid[data-columns="3"] { --cols: 3; }
  .assembly-grid[data-columns="2"] { --cols: 2; }
  .assembly-grid[data-columns="1"] { --cols: 1; }

  .assembly-edges {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    color: var(--ink-mute);
    z-index: 0;
  }

  .assembly-edges .edge {
    fill: none;
    stroke: rgba(250, 248, 244, 0.22);
    stroke-width: 1.25;
    transition: stroke 0.2s ease, stroke-width 0.2s ease;
  }

  .assembly-edges .edge.lit {
    stroke: var(--paprika);
    stroke-width: 1.75;
  }

  .assembly-col {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }

  .col-heading {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.5rem;
  }

  .col-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.55rem;
    height: 1.55rem;
    border: 1px solid var(--rule);
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0;
    color: var(--paprika);
    background: rgba(15, 18, 24, 0.5);
  }

  .col-nodes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }

  .col-nodes li {
    display: flex;
    flex: 1;
    min-height: 96px;
  }

  /* Image-led card. The hero photo becomes the card's background; text
   * is overlaid at the bottom on a soft gradient scrim. Cards flex to
   * fill the column so the whole graph stays in one viewport. */
  .node {
    position: relative;
    width: 100%;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-color: #11151a;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border: 1px solid var(--rule);
    border-radius: 8px;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.3;
    overflow: hidden;
    isolation: isolate;
    transition: border-color 0.2s ease, transform 0.2s ease, opacity 0.25s ease;
  }

  .node.faded { opacity: 0.32; }

  .node:hover {
    border-color: rgba(210, 84, 59, 0.55);
    transform: translateY(-1px);
  }

  /* Gradient scrim keeps the overlaid text legible regardless of photo. */
  .node-scrim {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.35) 45%, rgba(0,0,0,0.85) 100%);
  }
  .node:not([style*="background-image"]) {
    background: linear-gradient(160deg, rgba(20,24,32,1), rgba(10,13,17,1));
  }

  .node-content {
    position: relative;
    z-index: 1;
    padding: 0.65rem 0.8rem 0.75rem;
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.55rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.7), 0 0 12px rgba(0,0,0,0.4);
  }

  .node-glyph {
    grid-row: 1 / 4;
    align-self: start;
    font-size: 1.1rem;
    line-height: 1;
    margin-top: 0.18rem;
    color: var(--ink-soft);
  }

  .node-kind-tag {
    grid-column: 2;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(250, 248, 244, 0.78);
    margin-bottom: 0.1rem;
  }

  .node-label {
    grid-column: 2;
    font-family: var(--font-body);
    font-size: 0.97rem;
    font-weight: 500;
    color: var(--ink);
  }

  .node-meta {
    grid-column: 2;
    font-size: 0.78rem;
    color: rgba(250, 248, 244, 0.72);
    margin-top: 0.15rem;
  }

  .node-facts {
    grid-column: 2;
    list-style: none;
    padding: 0;
    margin: 0.3rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
  }

  .node-facts li {
    font-size: 0.76rem;
    color: rgba(250, 248, 244, 0.7);
    line-height: 1.35;
  }

  /* Per-kind glyph accents — small color cue on top of the photo. */
  .node-farm       .node-glyph { color: rgba(141, 178, 95, 0.95); }
  .node-garden     .node-glyph { color: rgba(141, 178, 95, 0.95); }
  .node-recipe     .node-glyph { color: rgba(232, 119, 90, 0.95); }
  .node-meal       .node-glyph { color: rgba(250, 248, 244, 0.95); }
  .node-restaurant .node-glyph { color: rgba(250, 248, 244, 0.95); }

  /* Discovered restaurants — dashed border + tinted kind-tag so it's
   * obvious at-a-glance the entry is sourced via research, not visited. */
  .node-restaurant.is-discovered {
    border-style: dashed;
    border-color: rgba(250, 248, 244, 0.22);
  }
  .node-restaurant.is-discovered .node-kind-tag {
    color: rgba(232, 119, 90, 0.92);
  }
  .node-restaurant.is-visited {
    border-color: rgba(141, 178, 95, 0.55);
  }

  @media (max-width: 720px) {
    .assembly-grid {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
    .col-heading { margin-top: 0.6rem; }
  }
</style>
