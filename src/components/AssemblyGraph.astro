---
/**
 * AssemblyGraph — Sankey-style flow lane.
 *
 *   ┌────────┐         ┌────────┐         ┌────────┐
 *   │ Farm A │──╮      │        │──╮      │ Meal   │
 *   ├────────┤  ╰─────→│ Recipe │  ├─────→├────────┤
 *   │ Farm B │  ╭─────→│        │  ├─────→│ Tandem │
 *   ├────────┤  │      └────────┘  ├─────→├────────┤
 *   │ Garden │──╯                  ├─────→│ Da Me  │
 *   └────────┘                     ├─────→├────────┤
 *                                  ├─────→│ Rezdôra│
 *                                  └─────→├────────┤
 *                                         │ LucAle │
 *                                         └────────┘
 *
 *   1 SOURCE                    2 COOK              3 EAT
 *
 * Cards stay as CSS-positioned HTML so they're readable. Ribbons
 * between columns are computed by d3-sankey (`sankeyLinkHorizontal`)
 * — proper Sankey path geometry, uniform width per ribbon (we have
 * no quantitative weights, so all = 1). One lane, continuous flow.
 *
 * The dish itself remains the page header above this section — it's
 * the subject of the flow, not a node in it.
 */

import type { AssemblyGraph, Node } from '~/lib/assembly';
import Card from './Card.astro';
import StageHeading from './StageHeading.astro';

interface Props {
  graph: AssemblyGraph;
}

const { graph } = Astro.props;

/* ---------- presentational helpers ---------- */

const href = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return `/farms/${n.slug}/`;
    case 'garden':     return `/garden/${n.slug}/`;
    case 'recipe':     return `/recipes/${n.slug}/`;
    case 'meal':       return `/meals/${n.slug}/`;
    case 'restaurant': return `/restaurants/${n.slug}/`;
  }
};

const kindLabel = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return 'Producer';
    case 'garden':     return 'Garden';
    case 'recipe':     return 'Recipe';
    case 'meal':       return 'Meal';
    case 'restaurant': return n.status === 'visited' ? 'Restaurant · visited' : 'Restaurant · discovered';
  }
};

const variant = (n: Node): 'default' | 'visited' | 'discovered' =>
  n.kind === 'restaurant' ? n.status : 'default';

/* ---------- three columns of the flow lane ----------
 * Source + Grow are parallel inputs to Cook, so they share column 1.
 * Cook is column 2 (the bottleneck). Eat is column 3 (the fan-out).
 */

const sourceCol = [...graph.source, ...graph.grow];
const cookCol   = graph.cook;
const eatCol    = graph.eat;

const hasSource = sourceCol.length > 0;
const hasCook   = cookCol.length > 0;
const hasEat    = eatCol.length > 0;
---

<section class="assembly" aria-label={`Lifecycle flow of ${graph.dish.label}`}>
  <div class="lane">
    <svg class="ribbons" aria-hidden="true" preserveAspectRatio="none">
      <defs>
        <linearGradient id="ribbonGradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%"  stop-color="rgba(232, 119, 90, 0.55)" />
          <stop offset="50%" stop-color="rgba(210, 84, 59, 0.35)" />
          <stop offset="100%" stop-color="rgba(232, 119, 90, 0.55)" />
        </linearGradient>
      </defs>
    </svg>

    {hasSource && (
      <div class="layer" data-layer="source">
        <StageHeading step={1} label="Source" />
        <ul class="layer-nodes">
          {sourceCol.map((n) => (
            <li>
              <Card
                href={href(n)}
                imageUrl={n.heroUrl}
                kindLabel={kindLabel(n)}
                label={n.label}
                meta={n.meta}
                facts={n.facts}
                variant={variant(n)}
                nodeId={`source--${n.slug}`}
              />
            </li>
          ))}
        </ul>
      </div>
    )}

    {hasCook && (
      <div class="layer" data-layer="cook">
        <StageHeading step={2} label="Cook" />
        <ul class="layer-nodes">
          {cookCol.map((n) => (
            <li>
              <Card
                href={href(n)}
                imageUrl={n.heroUrl}
                kindLabel={kindLabel(n)}
                label={n.label}
                meta={n.meta}
                facts={n.facts}
                variant={variant(n)}
                nodeId={`cook--${n.slug}`}
              />
            </li>
          ))}
        </ul>
      </div>
    )}

    {hasEat && (
      <div class="layer" data-layer="eat">
        <StageHeading step={3} label="Eat" />
        <ul class="layer-nodes">
          {eatCol.map((n) => (
            <li>
              <Card
                href={href(n)}
                imageUrl={n.heroUrl}
                kindLabel={kindLabel(n)}
                label={n.label}
                meta={n.meta}
                facts={n.facts}
                variant={variant(n)}
                nodeId={`eat--${n.slug}`}
              />
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>

<script>
  import { sankeyLinkHorizontal } from 'd3-sankey';

  const SVG_NS = 'http://www.w3.org/2000/svg';

  /** d3-sankey's link generator. Expects each link to carry source/target
   *  nodes with x1/y0 and x0/y1 (sankey conventions). Returns a proper
   *  Sankey ribbon path string. */
  const ribbonPath = sankeyLinkHorizontal();

  /** Per-ribbon stroke width. Uniform because we don't have quantitative
   *  weights — every ribbon represents "this flows to that". */
  const RIBBON_WIDTH = 14;

  function clearRibbons(svg: SVGSVGElement) {
    svg.querySelectorAll('path.ribbon').forEach((p) => p.remove());
  }

  function makeRibbon(
    svg: SVGSVGElement,
    sourceCard: HTMLElement,
    targetCard: HTMLElement,
    anchor: DOMRect,
  ): SVGPathElement {
    const sr = sourceCard.getBoundingClientRect();
    const tr = targetCard.getBoundingClientRect();

    // d3-sankey's generator wants a sankey-shaped link object. We mock
    // one — source.x1/y is the right-edge midpoint of the source card,
    // target.x0/y is the left-edge midpoint of the target card.
    const linkLike = {
      source: {
        x1: sr.right - anchor.left,
      },
      target: {
        x0: tr.left - anchor.left,
      },
      y0: sr.top + sr.height / 2 - anchor.top,
      y1: tr.top + tr.height / 2 - anchor.top,
      width: RIBBON_WIDTH,
    };

    const path = document.createElementNS(SVG_NS, 'path');
    path.setAttribute('d', ribbonPath(linkLike as never) ?? '');
    path.setAttribute('class', 'ribbon');
    path.dataset.from = sourceCard.dataset.nodeId ?? '';
    path.dataset.to = targetCard.dataset.nodeId ?? '';
    svg.appendChild(path);
    return path;
  }

  function draw(root: HTMLElement) {
    const svg = root.querySelector('svg.ribbons') as SVGSVGElement | null;
    const lane = root.querySelector('.lane') as HTMLElement | null;
    if (!svg || !lane) return;

    clearRibbons(svg);

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Render statically (no animation) but still draw the ribbons.
    }

    const anchor = lane.getBoundingClientRect();
    svg.setAttribute('viewBox', `0 0 ${anchor.width} ${anchor.height}`);
    svg.style.width = `${anchor.width}px`;
    svg.style.height = `${anchor.height}px`;

    const sourceCards = Array.from(root.querySelectorAll<HTMLAnchorElement>('[data-layer="source"] .card'));
    const cookCards   = Array.from(root.querySelectorAll<HTMLAnchorElement>('[data-layer="cook"] .card'));
    const eatCards    = Array.from(root.querySelectorAll<HTMLAnchorElement>('[data-layer="eat"] .card'));

    // Layer 1 → 2: every Source/Grow card to every Cook card.
    for (const s of sourceCards) {
      for (const c of cookCards) {
        makeRibbon(svg, s, c, anchor);
      }
    }
    // Layer 2 → 3: every Cook card to every Eat card.
    for (const c of cookCards) {
      for (const e of eatCards) {
        makeRibbon(svg, c, e, anchor);
      }
    }
    // Edge case: if there's no Cook layer, connect Source → Eat directly.
    if (cookCards.length === 0) {
      for (const s of sourceCards) {
        for (const e of eatCards) {
          makeRibbon(svg, s, e, anchor);
        }
      }
    }
  }

  function bindHover(root: HTMLElement) {
    root.addEventListener('mouseover', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLAnchorElement>('.card');
      if (!card) return;
      const id = card.dataset.nodeId;
      root.querySelectorAll<SVGPathElement>('path.ribbon').forEach((p) => {
        p.classList.toggle('lit', p.dataset.from === id || p.dataset.to === id);
      });
      const touched = new Set<string>([id ?? '']);
      root.querySelectorAll<SVGPathElement>('path.ribbon.lit').forEach((p) => {
        if (p.dataset.from) touched.add(p.dataset.from);
        if (p.dataset.to) touched.add(p.dataset.to);
      });
      root.querySelectorAll<HTMLAnchorElement>('.card').forEach((c) => {
        c.classList.toggle('faded', !touched.has(c.dataset.nodeId ?? ''));
      });
    });
    root.addEventListener('mouseleave', () => {
      root.querySelectorAll<SVGPathElement>('path.ribbon.lit')
        .forEach((p) => p.classList.remove('lit'));
      root.querySelectorAll<HTMLAnchorElement>('.card.faded')
        .forEach((c) => c.classList.remove('faded'));
    });
  }

  function init() {
    const root = document.querySelector('.assembly') as HTMLElement | null;
    if (!root) return;
    draw(root);
    bindHover(root);
    new ResizeObserver(() => draw(root)).observe(root);
    if ('fonts' in document) {
      document.fonts.ready.then(() => draw(root));
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  /* ============================================================
   *  Outer
   * ============================================================ */
  .assembly {
    width: 100%;
  }

  /* The flow lane — three columns side by side. Each column stretches
   * to the lane's height; cards are stacked vertically and centered
   * within the column. The Eat column with many cards stretches the
   * lane tall; the Source and Cook columns then center their few
   * cards in that height, producing the "fan-in / fan-out" geometry. */
  .lane {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: stretch;
    min-height: 60vh;
  }

  /* ============================================================
   *  Ribbons
   * ============================================================ */
  .ribbons {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    z-index: 0;
  }

  .ribbon {
    fill: none;
    stroke: url(#ribbonGradient);
    stroke-opacity: 0.55;
    mix-blend-mode: screen;
    transition: stroke-opacity 0.25s ease, stroke-width 0.25s ease;
    pathLength: 1;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: drawRibbon 1.1s cubic-bezier(0.4, 0, 0.2, 1) 0.15s forwards;
  }

  .ribbon.lit {
    stroke-opacity: 1;
    stroke: var(--paprika);
  }

  @keyframes drawRibbon {
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ribbon { animation: none; stroke-dashoffset: 0; }
  }

  /* ============================================================
   *  Columns
   * ============================================================ */
  .layer {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .layer-nodes {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }
  .layer-nodes li { display: flex; }

  /* The Cook column is the bottleneck; emphasise it slightly. */
  .layer[data-layer="cook"] .card {
    border-color: rgba(210, 84, 59, 0.35);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  }

  /* ============================================================
   *  Mobile — single column, no ribbons
   * ============================================================ */
  @media (max-width: 720px) {
    .lane {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .layer-nodes { justify-content: flex-start; }
    .ribbons { display: none; }
  }
</style>
