---
/**
 * AssemblyGraph — the chain leading to a dish, asymmetrically.
 *
 *   PRODUCTION CHAIN  →  Source → Grow → Cook    (3-col grid)
 *   ───────────────────────────────────────────
 *   CONSUMPTION GALLERY →  Eat                   (responsive auto-fill grid)
 *
 * The lifecycle has four stages, but their cardinality is asymmetric:
 * production typically has 1–3 entries per stage; Eat lists every meal
 * + every restaurant where the dish is served, which scales much wider.
 * Splitting at the natural seam keeps every card readable and the
 * lifecycle order intact.
 *
 * Card markup + styling lives in <Card>; stage headings in
 * <StageHeading>. This file owns *only* the layout: production grid,
 * connector SVG, the "to the table" bridge, and the eat-gallery grid.
 */

import type { AssemblyGraph, Node } from '~/lib/assembly';
import Card from './Card.astro';
import StageHeading from './StageHeading.astro';

interface Props {
  graph: AssemblyGraph;
}

const { graph } = Astro.props;

/* ---------- node → presentational props ---------- */

const href = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return `/farms/${n.slug}/`;
    case 'garden':     return `/garden/${n.slug}/`;
    case 'recipe':     return `/recipes/${n.slug}/`;
    case 'meal':       return `/meals/${n.slug}/`;
    case 'restaurant': return `/restaurants/${n.slug}/`;
  }
};

const kindLabel = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return 'Producer';
    case 'garden':     return 'Garden';
    case 'recipe':     return 'Recipe';
    case 'meal':       return 'Meal';
    case 'restaurant': return n.status === 'visited' ? 'Restaurant · visited' : 'Restaurant · discovered';
  }
};

const variant = (n: Node): 'default' | 'visited' | 'discovered' =>
  n.kind === 'restaurant' ? n.status : 'default';

/* ---------- stages ---------- */

const productionStages = [
  { id: 'source', step: 1, label: 'Source', nodes: graph.source },
  { id: 'grow',   step: 2, label: 'Grow',   nodes: graph.grow },
  { id: 'cook',   step: 3, label: 'Cook',   nodes: graph.cook },
].filter((s) => s.nodes.length > 0);

const hasProduction = productionStages.length > 0;
const hasEat = graph.eat.length > 0;
---

<section class="assembly" aria-label={`Lifecycle of ${graph.dish.label}`}>
  {hasProduction && (
    <div class="production" style={`--prod-cols: ${productionStages.length}`}>
      <svg class="production-edges" aria-hidden="true" preserveAspectRatio="none">
        <defs>
          <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5"
                  markerWidth="5" markerHeight="5" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
          </marker>
        </defs>
      </svg>

      {productionStages.map((stage) => (
        <div class={`stage stage-${stage.id}`} data-stage={stage.id}>
          <StageHeading step={stage.step} label={stage.label} />
          <ul class="stage-nodes">
            {stage.nodes.map((n) => (
              <li>
                <Card
                  href={href(n)}
                  imageUrl={n.heroUrl}
                  kindLabel={kindLabel(n)}
                  label={n.label}
                  meta={n.meta}
                  facts={n.facts}
                  variant={variant(n)}
                  nodeId={`${stage.id}--${n.slug}`}
                />
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  )}

  {hasProduction && hasEat && (
    <div class="to-eat" aria-hidden="true">
      <span class="to-eat-line"></span>
      <span class="to-eat-label">↓ to the table</span>
      <span class="to-eat-line"></span>
    </div>
  )}

  {hasEat && (
    <div class="eat">
      <StageHeading step={4} label="Eat" />
      <ul class="eat-grid">
        {graph.eat.map((n) => (
          <li>
            <Card
              href={href(n)}
              imageUrl={n.heroUrl}
              kindLabel={kindLabel(n)}
              label={n.label}
              meta={n.meta}
              facts={n.facts}
              variant={variant(n)}
              nodeId={`eat--${n.slug}`}
            />
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<script>
  /**
   * Production-row connectors. Cubic-bezier curves from every card in
   * stage N to every card in stage N+1, recomputed on resize and on
   * Astro page-load. Honors prefers-reduced-motion. Hover highlights
   * the subgraph touching a card and fades unconnected production cards.
   */
  function draw(root: HTMLElement) {
    const svg = root.querySelector('svg.production-edges') as SVGSVGElement | null;
    const prod = root.querySelector('.production') as HTMLElement | null;
    if (!svg || !prod) return;

    svg.querySelectorAll('path.edge').forEach((p) => p.remove());
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const rect = prod.getBoundingClientRect();
    svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
    svg.style.width = `${rect.width}px`;
    svg.style.height = `${rect.height}px`;

    const stages = Array.from(root.querySelectorAll<HTMLElement>('.production .stage'));
    const stacked = matchMedia('(max-width: 720px)').matches;

    for (let i = 0; i < stages.length - 1; i++) {
      const fromCards = Array.from(stages[i].querySelectorAll<HTMLAnchorElement>('.card'));
      const toCards = Array.from(stages[i + 1].querySelectorAll<HTMLAnchorElement>('.card'));

      for (const from of fromCards) {
        for (const to of toCards) {
          const fr = from.getBoundingClientRect();
          const tr = to.getBoundingClientRect();
          let x1: number, y1: number, x2: number, y2: number;
          let c1x: number, c1y: number, c2x: number, c2y: number;
          if (stacked) {
            x1 = fr.left + fr.width / 2 - rect.left;
            y1 = fr.bottom - rect.top;
            x2 = tr.left + tr.width / 2 - rect.left;
            y2 = tr.top - rect.top;
            const dy = Math.max(20, (y2 - y1) * 0.55);
            c1x = x1; c1y = y1 + dy;
            c2x = x2; c2y = y2 - dy;
          } else {
            x1 = fr.right - rect.left;
            y1 = fr.top + fr.height / 2 - rect.top;
            x2 = tr.left - rect.left;
            y2 = tr.top + tr.height / 2 - rect.top;
            const dx = Math.max(30, (x2 - x1) * 0.55);
            c1x = x1 + dx; c1y = y1;
            c2x = x2 - dx; c2y = y2;
          }
          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', `M ${x1} ${y1} C ${c1x} ${c1y}, ${c2x} ${c2y}, ${x2} ${y2}`);
          path.setAttribute('class', 'edge');
          path.dataset.from = from.dataset.nodeId ?? '';
          path.dataset.to = to.dataset.nodeId ?? '';
          svg.appendChild(path);
        }
      }
    }
  }

  function bindHover(root: HTMLElement) {
    root.addEventListener('mouseover', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLAnchorElement>('.card');
      if (!card) return;
      const id = card.dataset.nodeId;
      root.querySelectorAll<SVGPathElement>('path.edge').forEach((p) => {
        p.classList.toggle('lit', p.dataset.from === id || p.dataset.to === id);
      });
      const touched = new Set<string>([id ?? '']);
      root.querySelectorAll<SVGPathElement>('path.edge.lit').forEach((p) => {
        if (p.dataset.from) touched.add(p.dataset.from);
        if (p.dataset.to) touched.add(p.dataset.to);
      });
      root.querySelectorAll<HTMLAnchorElement>('.production .card').forEach((c) => {
        c.classList.toggle('faded', !touched.has(c.dataset.nodeId ?? ''));
      });
    });
    root.addEventListener('mouseleave', () => {
      root.querySelectorAll<SVGPathElement>('path.edge.lit')
        .forEach((p) => p.classList.remove('lit'));
      root.querySelectorAll<HTMLAnchorElement>('.card.faded')
        .forEach((c) => c.classList.remove('faded'));
    });
  }

  function init() {
    const root = document.querySelector('.assembly') as HTMLElement | null;
    if (!root) return;
    draw(root);
    bindHover(root);
    new ResizeObserver(() => draw(root)).observe(root);
    if ('fonts' in document) {
      document.fonts.ready.then(() => draw(root));
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  /* ============================================================
   *  Outer rhythm
   * ============================================================ */
  .assembly {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ============================================================
   *  Production chain — 3 columns side by side
   * ============================================================ */
  .production {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--prod-cols, 3), minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }

  .production-edges {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    color: var(--ink-mute);
    z-index: 0;
  }

  .production-edges .edge {
    fill: none;
    stroke: rgba(250, 248, 244, 0.22);
    stroke-width: 1.25;
    transition: stroke 0.2s ease, stroke-width 0.2s ease;
  }

  .production-edges .edge.lit {
    stroke: var(--paprika);
    stroke-width: 1.75;
  }

  .stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .stage-nodes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .stage-nodes li { display: flex; }

  /* ============================================================
   *  Bridge between production and consumption
   * ============================================================ */
  .to-eat {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin: 0.5rem 0 -0.5rem;
  }
  .to-eat-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--rule), transparent);
  }
  .to-eat-label {
    font-family: var(--font-body);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
  }

  /* ============================================================
   *  Consumption gallery — responsive auto-fill grid
   * ============================================================ */
  .eat-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .eat-grid li { display: flex; }

  /* ============================================================
   *  Mobile — stack production columns, collapse gallery to single
   * ============================================================ */
  @media (max-width: 720px) {
    .production {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .eat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
