---
/**
 * AssemblyGraph — the chain leading to a dish, asymmetrically.
 *
 *   PRODUCTION CHAIN (3-col):  Source → Grow → Cook
 *   ──────────────────────────────────────────────────
 *   CONSUMPTION GALLERY:        Eat (responsive grid)
 *
 * The lifecycle has four stages, but their cardinality is asymmetric:
 * production stages typically have 1–3 entries each (a few farms, one
 * garden bed, one recipe), whereas Eat can list many places the dish
 * was served. Forcing all four into one grid either crushes the Eat
 * cards into illegible sub-cells or balloons the page with empty space
 * in the production columns. Splitting at the natural seam keeps every
 * card readable and the lifecycle order intact.
 *
 * Cards use the traditional content-card pattern — image on top, text
 * block below — so the image is recognizable AND the label/meta/facts
 * read clearly. Cubic-bezier connectors curve between production
 * stages; a visual marker (↓ TO THE TABLE) bridges production to Eat.
 */

import type { AssemblyGraph, Node } from '~/lib/assembly';

interface Props {
  graph: AssemblyGraph;
}

const { graph } = Astro.props;

const href = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return `/farms/${n.slug}/`;
    case 'garden':     return `/garden/${n.slug}/`;
    case 'recipe':     return `/recipes/${n.slug}/`;
    case 'meal':       return `/meals/${n.slug}/`;
    case 'restaurant': return `/restaurants/${n.slug}/`;
  }
};

const kindLabel = (n: Node): string => {
  switch (n.kind) {
    case 'farm':       return 'Producer';
    case 'garden':     return 'Garden';
    case 'recipe':     return 'Recipe';
    case 'meal':       return 'Meal';
    case 'restaurant': return n.status === 'visited' ? 'Restaurant · visited' : 'Restaurant · discovered';
  }
};

const productionStages = [
  { id: 'source', heading: 'Source', step: 1, nodes: graph.source },
  { id: 'grow',   heading: 'Grow',   step: 2, nodes: graph.grow },
  { id: 'cook',   heading: 'Cook',   step: 3, nodes: graph.cook },
].filter((c) => c.nodes.length > 0);

const hasProduction = productionStages.length > 0;
const hasEat = graph.eat.length > 0;
---

<section class="assembly" aria-label={`Lifecycle of ${graph.dish.label}`}>
  {hasProduction && (
    <div class="production" style={`--prod-cols: ${productionStages.length}`}>
      <svg class="production-edges" aria-hidden="true" preserveAspectRatio="none">
        <defs>
          <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5"
                  markerWidth="5" markerHeight="5" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
          </marker>
        </defs>
      </svg>

      {productionStages.map((stage) => (
        <div class={`stage stage-${stage.id}`} data-stage={stage.id}>
          <p class="stage-heading">
            <span class="step">{stage.step}</span>
            <span>{stage.heading}</span>
          </p>
          <ul class="stage-nodes">
            {stage.nodes.map((n) => (
              <li>
                <a
                  class={`node node-${n.kind}`}
                  href={href(n)}
                  data-node-id={`${stage.id}--${n.slug}`}
                >
                  <div
                    class="node-image"
                    style={n.heroUrl ? `background-image: url('${n.heroUrl}')` : undefined}
                  />
                  <div class="node-body">
                    <span class="node-kind-tag">{kindLabel(n)}</span>
                    <span class="node-label" set:html={n.label} />
                    {n.meta && <span class="node-meta">{n.meta}</span>}
                    {n.facts && n.facts.length > 0 && (
                      <ul class="node-facts">
                        {n.facts.map((f) => <li>{f}</li>)}
                      </ul>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  )}

  {hasProduction && hasEat && (
    <div class="to-eat" aria-hidden="true">
      <span class="to-eat-line"></span>
      <span class="to-eat-label">↓ to the table</span>
      <span class="to-eat-line"></span>
    </div>
  )}

  {hasEat && (
    <div class="eat">
      <p class="stage-heading">
        <span class="step">4</span>
        <span>Eat</span>
      </p>
      <ul class="eat-grid">
        {graph.eat.map((n) => (
          <li>
            <a
              class={`node node-${n.kind} ${n.kind === 'restaurant' ? `is-${n.status}` : ''}`}
              href={href(n)}
              data-node-id={`eat--${n.slug}`}
            >
              <div
                class="node-image"
                style={n.heroUrl ? `background-image: url('${n.heroUrl}')` : undefined}
              />
              <div class="node-body">
                <span class="node-kind-tag">{kindLabel(n)}</span>
                <span class="node-label" set:html={n.label} />
                {n.meta && <span class="node-meta">{n.meta}</span>}
                {n.facts && n.facts.length > 0 && (
                  <ul class="node-facts">
                    {n.facts.map((f) => <li>{f}</li>)}
                  </ul>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<script>
  // Recompute production-row connectors. Only spans the production stages
  // (Source → Grow → Cook); the Eat gallery has no incoming connector
  // because the "↓ to the table" marker covers that visual bridge.
  function draw(root: HTMLElement) {
    const svg = root.querySelector('svg.production-edges') as SVGSVGElement | null;
    const prod = root.querySelector('.production') as HTMLElement | null;
    if (!svg || !prod) return;

    svg.querySelectorAll('path.edge').forEach((p) => p.remove());

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    const rect = prod.getBoundingClientRect();
    svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
    svg.style.width = `${rect.width}px`;
    svg.style.height = `${rect.height}px`;

    const stages = Array.from(root.querySelectorAll<HTMLElement>('.production .stage'));
    const stacked = matchMedia('(max-width: 720px)').matches;

    for (let i = 0; i < stages.length - 1; i++) {
      const fromNodes = Array.from(stages[i].querySelectorAll<HTMLAnchorElement>('.node'));
      const toNodes = Array.from(stages[i + 1].querySelectorAll<HTMLAnchorElement>('.node'));

      for (const from of fromNodes) {
        for (const to of toNodes) {
          const fr = from.getBoundingClientRect();
          const tr = to.getBoundingClientRect();

          let x1: number, y1: number, x2: number, y2: number;
          let c1x: number, c1y: number, c2x: number, c2y: number;
          if (stacked) {
            x1 = fr.left + fr.width / 2 - rect.left;
            y1 = fr.bottom - rect.top;
            x2 = tr.left + tr.width / 2 - rect.left;
            y2 = tr.top - rect.top;
            const dy = Math.max(20, (y2 - y1) * 0.55);
            c1x = x1; c1y = y1 + dy;
            c2x = x2; c2y = y2 - dy;
          } else {
            x1 = fr.right - rect.left;
            y1 = fr.top + fr.height / 2 - rect.top;
            x2 = tr.left - rect.left;
            y2 = tr.top + tr.height / 2 - rect.top;
            const dx = Math.max(30, (x2 - x1) * 0.55);
            c1x = x1 + dx; c1y = y1;
            c2x = x2 - dx; c2y = y2;
          }

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', `M ${x1} ${y1} C ${c1x} ${c1y}, ${c2x} ${c2y}, ${x2} ${y2}`);
          path.setAttribute('class', 'edge');
          path.dataset.from = from.dataset.nodeId ?? '';
          path.dataset.to = to.dataset.nodeId ?? '';
          svg.appendChild(path);
        }
      }
    }
  }

  function init() {
    const root = document.querySelector('.assembly') as HTMLElement | null;
    if (!root) return;
    draw(root);
    const ro = new ResizeObserver(() => draw(root));
    ro.observe(root);
    root.addEventListener('mouseover', (e) => {
      const node = (e.target as HTMLElement).closest<HTMLAnchorElement>('.node');
      if (!node) return;
      const id = node.dataset.nodeId;
      root.querySelectorAll<SVGPathElement>('path.edge').forEach((p) => {
        p.classList.toggle('lit', p.dataset.from === id || p.dataset.to === id);
      });
      root.querySelectorAll<HTMLAnchorElement>('.node').forEach((n) => n.classList.remove('faded'));
      const touched = new Set<string>([id ?? '']);
      root.querySelectorAll<SVGPathElement>('path.edge.lit').forEach((p) => {
        if (p.dataset.from) touched.add(p.dataset.from);
        if (p.dataset.to) touched.add(p.dataset.to);
      });
      // Only fade nodes in production (Eat gallery isn't part of the highlight graph).
      root.querySelectorAll<HTMLAnchorElement>('.production .node').forEach((n) => {
        if (!touched.has(n.dataset.nodeId ?? '')) n.classList.add('faded');
      });
    });
    root.addEventListener('mouseleave', () => {
      root.querySelectorAll<SVGPathElement>('path.edge.lit').forEach((p) => p.classList.remove('lit'));
      root.querySelectorAll<HTMLAnchorElement>('.node.faded').forEach((n) => n.classList.remove('faded'));
    });
    if ('fonts' in document) {
      document.fonts.ready.then(() => draw(root));
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .assembly {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ---- Production chain — 3 columns side by side ---- */
  .production {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--prod-cols, 3), minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }

  .production-edges {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    color: var(--ink-mute);
    z-index: 0;
  }

  .production-edges .edge {
    fill: none;
    stroke: rgba(250, 248, 244, 0.22);
    stroke-width: 1.25;
    transition: stroke 0.2s ease, stroke-width 0.2s ease;
  }

  .production-edges .edge.lit {
    stroke: var(--paprika);
    stroke-width: 1.75;
  }

  .stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* ---- Bridge from production to consumption ---- */
  .to-eat {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin: 0.5rem 0 -0.5rem;
  }
  .to-eat-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--rule), transparent);
  }
  .to-eat-label {
    font-family: var(--font-body);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    white-space: nowrap;
  }

  /* ---- Eat gallery — responsive auto-fill grid ---- */
  .eat-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .eat-grid li { display: flex; }

  /* ---- Stage heading ---- */
  .stage-heading {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.7rem;
  }

  .step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid var(--rule);
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 0.82rem;
    letter-spacing: 0;
    color: var(--paprika);
    background: rgba(15, 18, 24, 0.6);
  }

  .stage-nodes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .stage-nodes li { display: flex; }

  /* ============================================================
   *  Card — image on top, body below. Traditional content card.
   * ============================================================ */
  .node {
    width: 100%;
    display: flex;
    flex-direction: column;
    background: rgba(15, 18, 24, 0.92);
    border: 1px solid var(--rule);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.2s ease, border-color 0.2s ease,
                box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .node.faded { opacity: 0.32; }

  .node:hover {
    transform: translateY(-2px);
    border-color: rgba(210, 84, 59, 0.55);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
  }

  .node-image {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    background-color: #0a0d11;
    border-bottom: 1px solid var(--rule);
  }

  .node-body {
    padding: 0.8rem 0.95rem 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    line-height: 1.35;
  }

  .node-kind-tag {
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .node-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink);
  }

  .node-meta {
    font-size: 0.82rem;
    color: var(--ink-soft);
  }

  .node-facts {
    list-style: none;
    padding: 0;
    margin: 0.2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .node-facts li {
    font-size: 0.78rem;
    color: var(--ink-mute);
    line-height: 1.4;
  }

  /* Discovered restaurants — accent so they read differently from visited. */
  .node-restaurant.is-discovered {
    border-style: dashed;
    border-color: rgba(232, 119, 90, 0.32);
  }
  .node-restaurant.is-discovered .node-kind-tag {
    color: rgba(232, 119, 90, 0.92);
  }
  .node-restaurant.is-visited {
    border-color: rgba(141, 178, 95, 0.55);
  }

  @media (max-width: 720px) {
    .production {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .eat-grid {
      grid-template-columns: 1fr;
    }
    .stage-heading { margin-top: 0.6rem; }
  }
</style>
