---
/**
 * Landing-page dish card. Hero photo, title, optional tagline.
 */

interface Props {
  slug: string;
  title: string;
  tagline?: string;
  hero?: string;
  heroUrl?: string;
}

const { slug, title, tagline, hero, heroUrl } = Astro.props;
const photoUrl = heroUrl ?? (hero ? `${hero}-1280.jpg` : '');
---

<a class="dish-card" href={`/dishes/${slug}/`} aria-label={title}>
  <div
    class="photo"
    style={`background-image: url(${photoUrl})`}
  />
  <div class="overlay" />
  <div class="meta">
    <div class="title" set:html={title} />
    {tagline && <div class="tagline">{tagline}</div>}
  </div>
</a>
