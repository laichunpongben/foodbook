---
/**
 * Four-dot lifecycle stepper rendered at the top of a dish entry.
 * Stages present (any keys in `stages`) get the active treatment;
 * absent stages render greyed and non-clickable.
 *
 * Props:
 *   stages — record with optional source/grow/cook/eat keys.
 *   slug   — used to build the anchor links.
 */

interface Stage {
  note?: string;
}

interface Stages {
  source?: Stage;
  grow?: Stage;
  cook?: Stage;
  eat?: Stage;
}

interface Props {
  stages: Stages;
  slug: string;
}

const { stages, slug } = Astro.props;

const order = ['source', 'grow', 'cook', 'eat'] as const;
const labels: Record<typeof order[number], string> = {
  source: 'Source',
  grow: 'Grow',
  cook: 'Cook',
  eat: 'Eat',
};
---

<nav class="lifecycle-stepper" aria-label="Lifecycle stages">
  {order.map((stage) => {
    const present = Boolean(stages[stage]);
    if (!present) {
      return (
        <span class="dot empty" aria-disabled="true">{labels[stage]}</span>
      );
    }
    return (
      <a class="dot" href={`/dishes/${slug}/#stage-${stage}`} data-stage={stage}>
        {labels[stage]}
      </a>
    );
  })}
</nav>
