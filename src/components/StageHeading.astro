---
/**
 * StageHeading — numbered chip + uppercase stage label.
 *
 * Used by AssemblyGraph on each of the four lifecycle stages so the
 * order (1 Source → 2 Grow → 3 Cook → 4 Eat) is unambiguous.
 */

interface Props {
  step: number;
  label: string;
}

const { step, label } = Astro.props;
---

<p class="stage-heading">
  <span class="step">{step}</span>
  <span>{label}</span>
</p>

<style>
  .stage-heading {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.75rem;
  }

  .step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid var(--rule);
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 0.82rem;
    letter-spacing: 0;
    color: var(--paprika);
    background: rgba(15, 18, 24, 0.6);
  }
</style>
