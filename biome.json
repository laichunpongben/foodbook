{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.mjs",
      "scripts/**/*.ts",
      "scripts/**/*.tsx",
      "scripts/**/*.mjs",
      "scripts/**/*.cjs",
      "scripts/**/*.js",
      "*.mjs",
      "*.cjs",
      "*.ts",
      "!**/node_modules",
      "!**/dist",
      "!**/.astro",
      "!**/.wrangler",
      "!src/content"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
