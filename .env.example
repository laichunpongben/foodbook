# Copy to .env (gitignored) and fill in.

# Anthropic Claude API key — for /api/extract, /api/chat, /api/coach.
ANTHROPIC_API_KEY=

# Voyage AI key — for embeddings (build-time + reader-side chat).
VOYAGE_API_KEY=

# Author-time token for the CLI extract route. Long random string.
EXTRACT_TOKEN=

# Cloudflare API token — only needed for ad-hoc `wrangler deploy`.
CLOUDFLARE_API_TOKEN=
